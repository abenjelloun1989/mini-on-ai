# Copy this file to .env and fill in your values
# Never commit .env to version control

# Claude API (required for all generation)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Telegram (required for reporting)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Site URL (used in Telegram reports)
# During development: file:///Users/you/Dev/mini-on-factory/site/index.html
# After deployment: https://mini-on-ai.com
SITE_URL=http://localhost

# Gumroad (required for M11 auto-publishing)
# Get your API token at: https://app.gumroad.com/settings/advanced
GUMROAD_API_TOKEN=your_gumroad_api_token_here

# Default product price in US cents (500 = $5.00)
PRODUCT_PRICE_CENTS=500

# Reddit demand scanner — uses pullpush.io (free, no account or API key needed)
# Comma-separated subreddits to monitor for user needs
REDDIT_SUBREDDITS=n8n,automation,nocode,zapier,MakeNoCode,freelance,Entrepreneur,smallbusiness,productivity,ADHD,selfimprovement,LifeProTips,writing,blogging,freelanceWriters,learnprogramming,webdev,SideProject
