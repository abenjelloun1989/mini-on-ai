# Copy this file to .env and fill in your values
# Never commit .env to version control

# Claude API (required for all generation)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Telegram (required for reporting)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Site URL (used in Telegram reports)
# During development: file:///Users/you/Dev/mini-on-factory/site/index.html
# After deployment: https://your-site.com
SITE_URL=http://localhost
