# Copy this file to .env and fill in your values
# Never commit .env to version control

# Claude API (required for all generation)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Telegram (required for reporting)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Site URL (used in Telegram reports)
# During development: file:///Users/you/Dev/mini-on-factory/site/index.html
# After deployment: https://mini-on-ai.com
SITE_URL=http://localhost

# Gumroad (required for M11 auto-publishing)
# Get your API token at: https://app.gumroad.com/settings/advanced
GUMROAD_API_TOKEN=your_gumroad_api_token_here

# Default product price in US cents (500 = $5.00)
PRODUCT_PRICE_CENTS=500

# Brevo email capture — API key stays SERVER-SIDE only (Cloudflare Worker)
# 1. Deploy worker/subscribe.js to Cloudflare Workers
# 2. Add BREVO_API_KEY + BREVO_LIST_ID as Worker secrets (not here)
# 3. Paste the worker URL below
BREVO_SUBSCRIBE_URL=https://subscribe.YOUR-SUBDOMAIN.workers.dev

# Cloudflare Web Analytics (free — get token at cloudflare.com/web-analytics)
CF_ANALYTICS_TOKEN=your_cloudflare_analytics_token_here

# Twitter / X (required for twitter_post.py)
# Create app at: https://developer.twitter.com → Projects & Apps → New App
# Set app permissions to "Read and Write" before generating tokens
TWITTER_API_KEY=your_api_key_here
TWITTER_API_SECRET=your_api_secret_here
TWITTER_ACCESS_TOKEN=your_access_token_here
TWITTER_ACCESS_TOKEN_SECRET=your_access_token_secret_here

# Reddit demand scanner — uses pullpush.io (free, no account or API key needed)
# Comma-separated subreddits to monitor for user needs
REDDIT_SUBREDDITS=n8n,automation,nocode,zapier,MakeNoCode,freelance,Entrepreneur,smallbusiness,productivity,ADHD,selfimprovement,LifeProTips,writing,blogging,freelanceWriters,learnprogramming,webdev,SideProject
